# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public production site URL for canonical links, sitemap, and social metadata.
# Example: https://rickardflodin.com
NEXT_PUBLIC_SITE_URL=

# Supabase publishable key, used by server routes/proxy, e.g. sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (server-only, NEVER expose to the browser), e.g. sb_secret_...
# Used by server-only route handlers for privileged database/storage writes.
SUPABASE_SECRET_KEY=

# Resend credentials for customer invoices and photographer order notifications.
# The From address must be verified in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
