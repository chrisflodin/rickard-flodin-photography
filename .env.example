# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key, used by server routes/proxy, e.g. sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (server-only, NEVER expose to the browser), e.g. sb_secret_...
# Used by server-only route handlers for privileged database/storage writes.
SUPABASE_SECRET_KEY=

# Optional: restrict admin access to a single email address.
# If set, only this authenticated user is treated as admin.
ADMIN_EMAIL=
